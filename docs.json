{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sentinel",
  "redirects": [
    {
      "source": "/getting-started/supported-robots",
      "destination": "/getting-started/supported-hardware"
    },
    {
      "source": "/ros2/session-services",
      "destination": "/api/session-actions"
    },
    {
      "source": "/getting-started/choose-path",
      "destination": "/getting-started/supported-hardware"
    }
  ],
  "colors": {
    "primary": "#383d66",
    "light": "#929cd6",
    "dark": "#252840"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "system"
  },
  "background": {
    "decoration": "gradient"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": [
          "index",
          "getting-started/quickstart",
          "getting-started/supported-hardware"
        ]
      },
      {
        "group": "Setup",
        "pages": [
          "getting-started/install",
          "getting-started/configure-robot",
          {
            "group": "ROS 2 integration",
            "pages": [
              "ros2/overview",
              "ros2/control-interface",
              "ros2/camera-interface",
              "ros2/networking",
              {
                "group": "Worked examples",
                "pages": [
                  "ros2/examples/ros2-control",
                  "ros2/examples/i2rt-adapter"
                ]
              }
            ]
          }
        ]
      },
      {
        "group": "Operate",
        "pages": [
          "operate/teleoperation"
        ]
      },
      {
        "group": "Data collection",
        "pages": [
          "operate/collect-data",
          "operate/data-collection",
          "operate/datasets"
        ]
      },
      {
        "group": "Concepts",
        "pages": [
          "concepts/architecture",
          "concepts/streaming"
        ]
      },
      {
        "group": "API",
        "pages": [
          "api/session-actions"
        ]
      },
      {
        "group": "Help",
        "pages": [
          "troubleshooting",
          "coming-soon"
        ]
      },
      {
        "group": "Changelog",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Talk to us on Slack",
        "href": "https://avea-robotics.slack.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/getting-started/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://avearobotics.com"
    }
  }
}
